{
	"appVersion": "0.1.3",
	"calibrationVersion": "baseline-guided-upright-v3",
	"theme": "inverted-flat-jar-pastel-sand-v2",
	"participantIdParamNames": ["participantId", "subjectId", "pid"],
	"schedule": {
		"startRatio": 1,
		"growthBase": 2,
		"maxCoins": 12,
		"rounding": "round",
		"explicitRatios": []
	},
	"tutorial": {
		"ratios": [1, 2, 4]
	},
	"motion": {
		"calibrationSamplesRequired": 8,
		"baselineDurationMs": 1700,
		"calibrationLowFloorDps": 30,
		"calibrationBaselineMultiplier": 3.2,
		"calibrationBaselineMaxMultiplier": 1.25,
		"gameBaselineMultiplier": 3.7,
		"calibrationSampleCooldownMs": 700,
		"calibrationRankIndex": 2,
		"calibrationThresholdMultiplier": 0.72,
		"minimumThresholdDps": 30,
		"maximumThresholdDps": 420,
		"neutralReturnRatio": 0.62,
		"neutralReturnFloorDps": 28,
		"minimumGestureMs": 45,
		"maximumGestureMs": 900,
		"relaxedReturnAfterMs": 180,
		"relaxedReturnDropRatio": 0.58,
		"accelerationJerkScaleDps": 44,
		"debounceMs": 760,
		"postFlickSettleMs": 180,
		"postFlickSettleRatio": 0.45,
		"invalidLogCooldownMs": 550,
		"weakMovementFloorDps": 12,
		"sensorWarmupMs": 1800,
		"sensorLossMs": 5000
	},
	"orientation": {
		"lockPortrait": true,
		"requestFullscreenForLock": true
	},
	"session": {
		"idleWarningSeconds": 30,
		"idleTimeoutSeconds": 90,
		"endOnMaxCoins": true
	},
	"feedback": {
		"validVibrateMs": 20,
		"coinVibratePattern": [35, 40, 75],
		"idleWarningVibrateMs": 45,
		"soundEnabled": true
	},
	"backend": {
		"url": "",
		"method": "POST",
		"headers": {
			"Content-Type": "application/json"
		},
		"sendOnceAfterSession": true
	},
	"debug": {
		"allowKeyboardFlicks": true,
		"showSimulateButton": false,
		"logToConsole": true
	}
}
