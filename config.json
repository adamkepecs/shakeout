{
	"appVersion": "0.1.1",
	"calibrationVersion": "calibration-upright-easy-flick-v2",
	"theme": "glass-jar-river-rocks",
	"participantIdParamNames": ["participantId", "subjectId", "pid"],
	"schedule": {
		"startRatio": 1,
		"growthBase": 2,
		"maxCoins": 12,
		"rounding": "round",
		"explicitRatios": []
	},
	"tutorial": {
		"ratios": [1, 2, 4]
	},
	"motion": {
		"calibrationSamplesRequired": 8,
		"calibrationLowFloorDps": 28,
		"calibrationRankIndex": 1,
		"calibrationThresholdMultiplier": 0.58,
		"minimumThresholdDps": 24,
		"maximumThresholdDps": 420,
		"neutralReturnRatio": 0.78,
		"neutralReturnFloorDps": 30,
		"minimumGestureMs": 45,
		"maximumGestureMs": 900,
		"relaxedReturnAfterMs": 145,
		"relaxedReturnDropRatio": 0.84,
		"accelerationJerkScaleDps": 44,
		"debounceMs": 240,
		"invalidLogCooldownMs": 550,
		"weakMovementFloorDps": 12,
		"sensorWarmupMs": 1800,
		"sensorLossMs": 5000
	},
	"orientation": {
		"lockPortrait": true,
		"requestFullscreenForLock": true
	},
	"session": {
		"idleWarningSeconds": 30,
		"idleTimeoutSeconds": 90,
		"endOnMaxCoins": true
	},
	"feedback": {
		"validVibrateMs": 20,
		"coinVibratePattern": [35, 40, 75],
		"idleWarningVibrateMs": 45,
		"soundEnabled": true
	},
	"backend": {
		"url": "",
		"method": "POST",
		"headers": {
			"Content-Type": "application/json"
		},
		"sendOnceAfterSession": true
	},
	"debug": {
		"allowKeyboardFlicks": true,
		"showSimulateButton": false,
		"logToConsole": true
	}
}
